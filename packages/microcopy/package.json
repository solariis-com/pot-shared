{
  "name": "@solariis-com/pot-microcopy",
  "version": "0.1.3",
  "description": "ES-VE / EN microcopy catalog for POT MVP",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./es": {
      "types": "./dist/catalog/es.d.ts",
      "import": "./dist/catalog/es.js",
      "require": "./dist/catalog/es.cjs"
    },
    "./en": {
      "types": "./dist/catalog/en.d.ts",
      "import": "./dist/catalog/en.js",
      "require": "./dist/catalog/en.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/solariis-com/pot-shared.git",
    "directory": "packages/microcopy"
  }
}
